DATABASE_URL=sqlite:///./data/muestras.db
# Usa una URL accesible desde otros portatiles/moviles para que los QR funcionen.
# Ejemplo red local: http://192.168.1.100:8000
# Ejemplo futuro: https://muestras.indianecotrade.es
APP_BASE_URL=http://localhost:8000
UPLOADS_DIR=./uploads
SECRET_KEY=supersecret
DEBUG=true

# Integracion ERP Indian solo lectura.
# Valores:
# - file: usa ERP_DATA_PATH con CSV/XLSX exportado.
# - apps_script: consulta ERP_APPS_SCRIPT_URL; si falla, la UI muestra ERP no disponible.
ERP_SOURCE=file
ERP_DATA_PATH=
ERP_APPS_SCRIPT_URL=
